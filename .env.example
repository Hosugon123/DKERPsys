# 複製為 .env 或 .env.local 後依環境調整（Vite 只會暴露前綴 VITE_ 的變數至前端）

# 儲存後端：localStorage（現行本機）｜remote（預留 Cloud SQL／REST）
VITE_STORAGE_MODE=localStorage

# 遠端 API 根 URL（僅 VITE_STORAGE_MODE=remote 時使用，勿結尾斜線）
# VITE_API_URL=https://your-cloud-run-service-xxxxx.run.app

# 模擬非同步延遲毫秒數（0–2000），便於本地體驗未來網路延遲
# VITE_ASYNC_STORAGE_DELAY_MS=50

# 忘記密碼：本機無郵件伺服器時是否在畫面顯示驗證碼（正式上線請設 false）
# VITE_SHOW_RESET_CODE=true
# 後端寄信 API（POST JSON { "email": "...", "code": "123456" }）；設定後將不顯示示範驗證碼
# VITE_PASSWORD_RESET_EMAIL_URL=https://your-worker.example.com/api/send-password-reset
