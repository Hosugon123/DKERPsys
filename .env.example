# 複製為 .env 或 .env.local 後依環境調整（Vite 只會暴露前綴 VITE_ 的變數至前端）

# 儲存後端：localStorage（現行本機）｜remote（Vercel API + KV 同步）
VITE_STORAGE_MODE=localStorage

# 遠端 API 根 URL（remote 時使用；留空時預設走同網域 /api）
# VITE_API_URL=https://your-app.vercel.app/api

# 前端送往 /api/sync-bundle 的 Bearer token（需與 Vercel 後端 API_SYNC_TOKEN 一致）
# VITE_API_SYNC_TOKEN=replace-with-long-random-token

# 後端同步 API（Vercel Function）使用的伺服器端 token
# API_SYNC_TOKEN=replace-with-the-same-long-random-token

# 後端儲存使用 Redis（由 Vercel Storage 連線後自動注入）
# REDIS_URL=redis://default:password@host:port

# 模擬非同步延遲毫秒數（0–2000），便於本地體驗未來網路延遲
# VITE_ASYNC_STORAGE_DELAY_MS=50

# 忘記密碼：本機無郵件伺服器時是否在畫面顯示驗證碼（正式上線請設 false）
# VITE_SHOW_RESET_CODE=true

# 忘記密碼寄信：production 前端預設呼叫同網域 /api/password-reset-email。
# 下列兩個是 Vercel Function 伺服器端環境變數，請勿加 VITE_，避免密鑰進入前端 bundle。
# PASSWORD_RESET_EMAIL_URL=https://your-worker.example.com/api/send-password-reset
# PASSWORD_RESET_EMAIL_AUTH=Bearer replace-with-mailer-secret

# 若你不用同網域 proxy，才設定前端公開的寄信 API URL；不得包含私密 token。
# VITE_PASSWORD_RESET_EMAIL_URL=https://your-public-mailer-endpoint.example.com/api/send-password-reset
